# ========================================================
#  SmashRank - .gitignore
# ========================================================

# Maven
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# Maven Wrapper
.mvn/wrapper/maven-wrapper.properties

# IDE - IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# IDE - Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# IDE - VS Code
.vscode/

# Spring Boot
spring-shell.log

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Credenciales y secretos — NUNCA subir esto
application-prod.properties
application-secrets.properties
*.env
.env

# Compiled class files
*.class

# Angular
frontend/.angular/cache/
frontend/dist/
frontend/node_modules/

# Jar / War
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
