# ========================================================
# SmashRank - Archivo de Configuración de Entorno (.env)
# Copia este archivo como ".env" en esta misma carpeta y
# rellena con tus credenciales reales de Start.gg.
# ========================================================

# 1. Tu Token de desarrollador personal de Start.gg (para llamadas GraphQL estándar)
STARTGG_API_TOKEN=TU_TOKEN_PERSONAL_DE_STARTGG

# 2. Las credenciales de tu aplicación OAuth2 registrada en Start.gg
# Registra tu aplicación en: https://start.gg/admin/developer
# Configura la URL de redirección (Redirect URI) como: http://localhost/auth/callback
STARTGG_CLIENT_ID=TU_CLIENT_ID_DE_OAUTH
STARTGG_CLIENT_SECRET=TU_CLIENT_SECRET_DE_OAUTH

# 3. URI de redirección local (se calcula sola en puerto 4200 por defecto)
STARTGG_REDIRECT_URI=http://localhost:4200/auth/callback
STARTGG_COUNTRY_FILTER=Spain
STARTGG_REGION_FILTER=Andalusia
